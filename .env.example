# Stuck_LLM local environment template
#
# Copy to `.env` only if you want shell-loaded local settings. Do not commit `.env`.

STUCK_LLM_STATE_PATH=.local/stuck_llm_state.json

# Optional hosted guard for non-local exposure.
STUCK_LLM_REQUIRE_API_KEY=false
STUCK_LLM_API_KEY=

# Optional credential encryption master key. If omitted in local mode, a development
# key is generated at `.local/stuck_llm_credential.key`.
STUCK_LLM_CREDENTIAL_KEY=
STUCK_LLM_CREDENTIAL_KEY_PATH=

# Live LLM provider keys are entered in Settings > Model and encrypted in local state.
# Environment variables are not used as LLM API-key fallbacks.

# Optional provider network policy. Keep custom providers disabled unless you
# explicitly trust the endpoint. Private base URLs are local-development only.
STUCK_LLM_ALLOW_CUSTOM_PROVIDER=false
STUCK_LLM_ALLOW_PRIVATE_BASE_URL=false
STUCK_LLM_PROVIDER_EGRESS_ALLOWLIST=

# Local frontend CORS defaults are used when omitted.
STUCK_LLM_CORS_ORIGINS=

# Optional external data providers for phase_019 search/news ingestion.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
TAVILY_API_KEY=
GNEWS_API_KEY=
EVENTREGISTRY_API_KEY=
DART_API_KEY=

# Optional US market snapshots through SerpApi Google Finance.
SERPAPI_API_KEY=
