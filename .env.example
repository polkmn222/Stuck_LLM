# Stuck_LLM local environment template
#
# Copy to `.env` only if you want shell-loaded local settings. Do not commit `.env`.

STUCK_LLM_STATE_PATH=.local/stuck_llm_state.json

# Optional hosted guard for non-local exposure.
STUCK_LLM_REQUIRE_API_KEY=false
STUCK_LLM_API_KEY=

# Optional credential encryption master key. If omitted in local mode, a development
# key is generated at `.local/stuck_llm_credential.key`.
STUCK_LLM_CREDENTIAL_KEY=
STUCK_LLM_CREDENTIAL_KEY_PATH=

# Local frontend CORS defaults are used when omitted.
STUCK_LLM_CORS_ORIGINS=
